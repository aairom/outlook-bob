# Environment files — never commit secrets
.env

# Node modules
node_modules/

# Virtual environment
.venv/
venv/

# Folders starting with underscore (local/private data)
_*/

# Output files (generated artifacts)
output/
**/output/

# Playwright MCP folder
.playwright-mcp/

# Python cache
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
dist/
build/

# macOS metadata
.DS_Store

# Token cache (local auth tokens)
extract_outlook_token.json

# Bob MCP config — contains API tokens (Monday JWT, etc.)
.bob/mcp.json

# Binary / large files — never commit
*.onnx
*.onnx.data
*.so
*.dylib
*.tgz
*.tar.gz
*.zip
