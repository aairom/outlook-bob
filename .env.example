# ──────────────────────────────────────────────────────────────────────────────
# Outlook Recipients Extractor — single configuration file for ALL app versions
# Copy this file to .env and fill in your values. Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# Azure AD App Registration client ID (public Graph Explorer client works by default)
CLIENT_ID=1234567890

# Email domain suffix to exclude from results (used as the default pre-fill in the UI)
# You can also change this value directly in the app's "Exclude addresses containing" field
EXCLUDED_DOMAIN=.xxx.com

# Base name for the timestamped output CSV file
OUTPUT_FILE=abc.csv

# OAuth redirect URI
# Use http://localhost:8765 for: Python, PyInstaller, Go CLI, Electron, and the
#   TypeScript web app when PORT=8765 (the root handler auto-detects the OAuth callback)
# Use http://localhost:3001/callback for: TypeScript web app when PORT=3001
REDIRECT_URI=http://localhost:8765

# Your Microsoft account email — pre-selects the correct account at sign-in
# Leave empty if not needed
LOGIN_HINT=

# Comma-separated Outlook folder names to scan (Graph API well-known names)
# Examples: SentItems   |   SentItems,Drafts   |   SentItems,Archive
MAIL_FOLDERS=SentItems

# ── Box integration (IBM Enterprise Box — ibm.ent.box.com) ───────────────────
# OAuth 2.0 app registered at ibm.ent.box.com/developers/console
# BOX_CLIENT_ID     — Application client ID
# BOX_CLIENT_SECRET — Application client secret
# BOX_REDIRECT_URI  — Must match the redirect URI set in the Box app console
#                     (default: http://localhost:8766 — different port from Microsoft)
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_REDIRECT_URI=http://localhost:8766

# ── Monday.com integration ────────────────────────────────────────────────────
# Base URL for your Monday.com account (used to build item deep-links in the UI)
# Format: https://<your-subdomain>.monday.com  — or https://monday.com for personal accounts
MONDAY_BASE_URL=https://monday.com

# ── TypeScript web app only ───────────────────────────────────────────────────
# Port the local web server listens on (also update REDIRECT_URI above if changed)
PORT=3001
